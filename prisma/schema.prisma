generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Empresa {
  id        String    @id
  nombre    String
  plan      String
  activo    Boolean
  createdAt DateTime
  updatedAt DateTime
  usuarios  Usuario[]
}

model Usuario {
  id        String   @id
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  nombre    String
  email     String
  activo    Boolean
  createdAt DateTime
  updatedAt DateTime
}
