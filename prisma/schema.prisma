generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Empresa {
  id                  String            @id
  nombre              String
  plan                String
  activo              Boolean
  createdAt           DateTime
  updatedAt           DateTime
  suscripciones       Suscripcion[]
  configuracion       Configuracion?
  roles               Rol[]
  agents              Agent[]
}

model Usuario {
  id           String       @id
  nombre       String
  email        String       @unique
  passwordHash String
  activo       Boolean
  createdAt    DateTime
  updatedAt    DateTime

  memberships  Membership[]
}

enum PlanIntervalo {
  MENSUAL
  ANUAL
}

model Plan {
  id            String        @id
  nombre        String
  slug          String        @unique
  descripcion   String
  precio        Decimal
  intervalo     PlanIntervalo
  activo        Boolean
  createdAt     DateTime
  updatedAt     DateTime
  suscripciones Suscripcion[]

  @@index([activo])
}

model Suscripcion {
  id          String    @id
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id])
  planId      String
  plan        Plan      @relation(fields: [planId], references: [id])
  fechaInicio DateTime
  fechaFin    DateTime?
  estado      String
  activo      Boolean
  createdAt   DateTime
  updatedAt   DateTime
}

model Configuracion {
  id                  String   @id
  empresaId           String   @unique
  empresa             Empresa  @relation(fields: [empresaId], references: [id])
  idioma              String
  zonaHoraria         String
  notificacionesEmail Boolean
  activo              Boolean
  createdAt           DateTime
  updatedAt           DateTime
}

enum ConversationStatusType {
  OPEN
  WAITING_AGENT
  HANDOFF
  CLOSED
  ARCHIVED
}

enum MessageRoleType {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model Conversation {
  id          String                 @id
  empresaId   String
  clienteId   String
  titulo      String?
  status      ConversationStatusType
  createdAt   DateTime
  updatedAt   DateTime

  messages    Message[]

  @@index([empresaId])
  @@index([clienteId])
}

model Message {
  id            String           @id
  conversationId String
  conversation  Conversation     @relation(fields: [conversationId], references: [id])
  empresaId     String
  usuarioId     String
  content       String
  role          MessageRoleType
  createdAt     DateTime

  @@index([conversationId])
  @@index([empresaId])
}

model Agent {
  id          String   @id
  empresaId   String
  name        String
  description String?
  status      String
  runtimeId   String?
  definition  Json
  settings    Json
  metadata    Json?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  empresa     Empresa @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@index([empresaId, status])
}

enum RoleType {
  GLOBAL
  TENANT
}

model Rol {
  id          String     @id
  empresaId   String?
  empresa     Empresa?   @relation(fields: [empresaId], references: [id])
  tipo        RoleType
  nombre      String
  descripcion String?
  activo      Boolean
  createdAt   DateTime
  updatedAt   DateTime

  memberships Membership[]
  rolPermisos RolPermiso[]
}

model Permiso {
  id          String      @id
  nombre      String
  slug        String      @unique
  descripcion String?
  activo      Boolean
  createdAt   DateTime
  updatedAt   DateTime

  rolPermisos RolPermiso[]
}

model Membership {
  id        String   @id
  usuarioId String
  empresaId String
  rolId     String
  activo    Boolean
  createdAt DateTime
  updatedAt DateTime

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  rol       Rol      @relation(fields: [rolId], references: [id])

  @@unique([usuarioId, empresaId])
  @@index([empresaId])
}

model RolPermiso {
  id        String   @id
  rolId     String
  permisoId String
  rol       Rol      @relation(fields: [rolId], references: [id])
  permiso   Permiso  @relation(fields: [permisoId], references: [id])
  activo    Boolean
  createdAt DateTime
  updatedAt DateTime

  @@unique([rolId, permisoId])
}
