generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model Empresa {
  id        String   @id
  nombre    String
  plan      String
  activo    Boolean
  createdAt DateTime
  updatedAt DateTime
}

model Usuario {
  id        String   @id
  nombre    String
  email     String
  activo    Boolean
  createdAt DateTime
  updatedAt DateTime
}
