generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Empresa {
  id                  String            @id
  nombre              String
  plan                String
  activo              Boolean
  createdAt           DateTime
  updatedAt           DateTime
  suscripciones       Suscripcion[]
  configuracion       Configuracion?
  roles               Rol[]
  agents              Agent[]
  tasks               Task[]
  workflowDefinitions WorkflowDefinition[]
  workflowExecutions  WorkflowExecution[]
  workflowStepExecutions WorkflowStepExecution[]
}

model Usuario {
  id           String       @id
  nombre       String
  email        String       @unique
  passwordHash String
  activo       Boolean
  createdAt    DateTime
  updatedAt    DateTime

  memberships  Membership[]
}

enum PlanIntervalo {
  MENSUAL
  ANUAL
}

model Plan {
  id            String        @id
  nombre        String
  slug          String        @unique
  descripcion   String
  precio        Decimal
  intervalo     PlanIntervalo
  activo        Boolean
  createdAt     DateTime
  updatedAt     DateTime
  suscripciones Suscripcion[]

  @@index([activo])
}

model Suscripcion {
  id          String    @id
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id])
  planId      String
  plan        Plan      @relation(fields: [planId], references: [id])
  fechaInicio DateTime
  fechaFin    DateTime?
  estado      String
  activo      Boolean
  createdAt   DateTime
  updatedAt   DateTime
}

model Configuracion {
  id                  String   @id
  empresaId           String   @unique
  empresa             Empresa  @relation(fields: [empresaId], references: [id])
  idioma              String
  zonaHoraria         String
  notificacionesEmail Boolean
  activo              Boolean
  createdAt           DateTime
  updatedAt           DateTime
}

enum ConversationStatusType {
  OPEN
  BOT_ACTIVE
  HUMAN_INTERVENTION
  BLOCKED
  WAITING_AGENT
  HANDOFF
  CLOSED
  ARCHIVED
}

enum MessageRoleType {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model Conversation {
  id          String                 @id
  empresaId   String
  clienteId   String
  titulo      String?
  status      ConversationStatusType
  createdAt   DateTime
  updatedAt   DateTime

  messages    Message[]

  @@index([empresaId])
  @@index([clienteId])
}

model Message {
  id            String           @id
  conversationId String
  conversation  Conversation     @relation(fields: [conversationId], references: [id])
  empresaId     String
  usuarioId     String
  content       String
  role          MessageRoleType
  createdAt     DateTime

  @@index([conversationId])
  @@index([empresaId])
}

model Agent {
  id          String   @id
  empresaId   String
  name        String
  description String?
  status      String
  runtimeId   String?
  definition  Json
  settings    Json
  metadata    Json?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  empresa     Empresa @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@index([empresaId, status])
}

enum RoleType {
  GLOBAL
  TENANT
}

model Rol {
  id          String     @id
  empresaId   String?
  empresa     Empresa?   @relation(fields: [empresaId], references: [id])
  tipo        RoleType
  nombre      String
  descripcion String?
  activo      Boolean
  createdAt   DateTime
  updatedAt   DateTime

  memberships Membership[]
  rolPermisos RolPermiso[]
}

model Permiso {
  id          String      @id
  nombre      String
  slug        String      @unique
  descripcion String?
  activo      Boolean
  createdAt   DateTime
  updatedAt   DateTime

  rolPermisos RolPermiso[]
}

model Membership {
  id        String   @id
  usuarioId String
  empresaId String
  rolId     String
  activo    Boolean
  createdAt DateTime
  updatedAt DateTime

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  rol       Rol      @relation(fields: [rolId], references: [id])

  @@unique([usuarioId, empresaId])
  @@index([empresaId])
}

model RolPermiso {
  id        String   @id
  rolId     String
  permisoId String
  rol       Rol      @relation(fields: [rolId], references: [id])
  permiso   Permiso  @relation(fields: [permisoId], references: [id])
  activo    Boolean
  createdAt DateTime
  updatedAt DateTime

  @@unique([rolId, permisoId])
}

enum TaskType {
  HUMAN
  AUTOMATED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  WAITING
  COMPLETED
  FAILED
  CANCELLED
}

model Task {
  id                 String      @id
  empresaId          String
  empresa            Empresa     @relation(fields: [empresaId], references: [id])
  workflowExecutionId String?
  workflowStepId     String?
  title              String
  description        String?
  type               TaskType
  priority           TaskPriority
  assignedTo         String?
  status             TaskStatus
  sla                Json?
  input              Json?
  result             Json?
  metadata           Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  resolvedAt         DateTime?

  @@index([empresaId])
  @@index([empresaId, status])
  @@index([empresaId, workflowExecutionId])
}

// Workflow models
model WorkflowDefinition {
  id          String   @id
  empresaId   String
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  name        String
  description String?
  version     String
  steps       Json
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  executions  WorkflowExecution[]

  @@index([empresaId])
}

model WorkflowExecution {
  id                    String    @id
  empresaId             String
  empresa               Empresa   @relation(fields: [empresaId], references: [id])
  workflowDefinitionId  String
  workflowDefinition    WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id])
  workflowVersion       String
  correlationId         String?
  currentStepIndex      Int
  status                String
  input                 Json?
  output                Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  stepExecutions        WorkflowStepExecution[]

  @@index([empresaId])
  @@index([empresaId, workflowDefinitionId])
}

model WorkflowStepExecution {
  id           String   @id
  empresaId    String
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  executionId  String
  execution    WorkflowExecution @relation(fields: [executionId], references: [id])
  stepId       String
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  status       String
  input        Json?
  output       Json?
  retries      Int      @default(0)

  @@index([empresaId, executionId])
}

enum SeverityType {
  INFO
  WARNING
  CRITICAL
}

model SystemEventLog {
  id          String       @id @default(uuid())
  severity    SeverityType @default(INFO)
  type        String
  ipAddress   String       @db.VarChar(45)
  endpoint    String
  metadata    Json
  createdAt   DateTime     @default(now())

  @@index([ipAddress])
  @@index([type])
  @@index([createdAt])
}
